# Copy to `.env` in this directory (do not commit `.env`).
# Used by docker-compose for LiteLLM, BiFrost, and the gateway.

# Gateway → upstream (BiFrost or LiteLLM): Bearer token. Must match `litellm.api_key_env` in config/gateway.yaml (default CLAUDIA_UPSTREAM_API_KEY).
# For BiFrost without governance keys, any non-empty placeholder is fine (Compose default: bifrost-local-dummy).
# For LiteLLM, set this to the same value as LITELLM_MASTER_KEY.
CLAUDIA_UPSTREAM_API_KEY=bifrost-local-dummy

# Required for LiteLLM service — proxy master key; not used by the gateway when api_key_env is CLAUDIA_UPSTREAM_API_KEY.
LITELLM_MASTER_KEY=sk-litellm-change-me

# Admin UI login — mapped to UI_USERNAME / UI_PASSWORD inside the litellm container.
# Requires PostgreSQL (DATABASE_URL below); without it, login often fails with “Invalid credentials”.
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=your-ui-secret

# PostgreSQL for LiteLLM (UI + virtual keys). Must match DATABASE_URL built in docker-compose.yml.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm-dev-change-me
POSTGRES_DB=litellm

# At least one provider key should match models in config/litellm_config.yaml
# BiFrost (docker compose service `bifrost`) reads the same vars via config/bifrost.config.json.
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional — pino log level for the gateway (debug, info, warn, error).
LOG_LEVEL=debug
