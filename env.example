# Optional: copy to `.env` in the working directory (do not commit `.env`).
# The Go `claudia` binary loads this at startup (github.com/joho/godotenv).

# Gateway → upstream (BiFrost): Bearer on /v1/*. Overrides `upstream.api_key` in config/gateway.yaml when set (non-empty).
# If unset, use upstream.api_key from gateway.yaml (or auto-generated on first start if omitted there too).
# BiFrost without governance keys: any non-empty value is fine.
CLAUDIA_UPSTREAM_API_KEY=bifrost-local-dummy

# BiFrost reads these from the process environment (`config/bifrost.config.json`).
# GROQ_API_KEY=
# GEMINI_API_KEY=
# BiFrost does not read this ENV but it is here for later when it could
# OLLAMA_BASE_URL="http://localhost:11434"

# Optional — overrides `gateway.log_level` when set (debug, info, warn, error).
LOG_LEVEL=info

# Optional — if set to a valid gateway token (same as tokens.yaml), the server issues the admin UI session on GET /ui/login (no form submit). Do not use in shared or production hosts.
# CLAUDIA_LOGIN_TOKEN=
